const icon = ICONS[name];
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 24 24"
  fill={icon.fill ?? "none"}
  stroke={icon.stroke ?? "currentColor"}
  stroke-width={icon.strokeWidth ?? 1.5}
  aria-hidden="true"
  data-slot="icon"
>
  {
    icon.paths.map((path) => (
      <path d={path} stroke-linecap="round" stroke-linejoin="round" />
    ))
  }
</svg>
