---
import { SITE } from "../config/site";
import "../styles/global.css";

type Props = {
  canonical?: string;
  description?: string;
  image?: string;
  title?: string;
};

const {
  canonical = new URL(Astro.url.pathname, Astro.site).toString(),
  description = SITE.description,
  image = SITE.socialImage,
  title = SITE.name,
} = Astro.props;

const pathname = Astro.url.pathname;
const currentYear = new Date().getFullYear();

const navLinks = [
  { href: "/", label: "home" },
  { href: "/about", label: "about" },
  { href: "/thoughts", label: "thoughts" },
];

function navClass(href: string) {
  const isActive = pathname === href || pathname.startsWith(`${href}/`);
  return [
    "text-primary text-lg font-medium tracking-tight transition-colors duration-200 hover:text-emerald-500 sm:text-base dark:hover:text-emerald-300",
    isActive ? "text-link" : "",
  ]
    .filter(Boolean)
    .join(" ");
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1" name="viewport" />
    <title>{title}</title>
    <meta content={description} name="description" />
    <link href={canonical} rel="canonical" />
    <meta
      content="#f4f4f5"
      name="theme-color"
      media="(prefers-color-scheme: light)"
    />
    <meta
      content="#18181b"
      name="theme-color"
      media="(prefers-color-scheme: dark)"
    />
    <meta content={title} property="og:title" />
    <meta content={description} property="og:description" />
    <meta content={canonical} property="og:url" />
    <meta content="website" property="og:type" />
    <meta content={image} property="og:image" />
    <meta content={SITE.twitterHandle} name="twitter:creator" />
    <meta content={SITE.twitterHandle} name="twitter:site" />
    <meta content="summary_large_image" name="twitter:card" />
    <meta content={title} name="twitter:title" />
    <meta content={description} name="twitter:description" />
    <meta content={image} name="twitter:image" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <link
