---
import type { MarkdownLayoutProps } from "astro";

import { SITE } from "../config/site";
import Layout from "./layout.astro";

type ThoughtFrontmatter = {
  createdAt: string;
  excerpt: string;
  readingTime: string;
  slug: string;
  title: string;
};

const { frontmatter } = Astro.props as MarkdownLayoutProps<ThoughtFrontmatter>;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const image = new URL(
  `/assets/thoughts/${frontmatter.slug}/meta.png`,
  Astro.site,
).toString();
---

<Layout
  title={`${frontmatter.title} | ${SITE.name}`}
  description={frontmatter.excerpt}
  canonical={canonical}
  image={image}
>
  <header class="section-stack">
    <div class="space-y-4">
      <h1>{frontmatter.title}</h1>
      <div
        class="text-sm font-medium uppercase tracking-[0.18em] text-zinc-600 dark:text-zinc-400"
      >
        <span>{frontmatter.createdAt}</span> · <span
          >{frontmatter.readingTime}</span
        >
      </div>
    </div>
  </header>

  <article class="prose-wrapper">
    <slot />
  </article>
</Layout>
