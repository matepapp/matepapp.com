---
import CareerTimelineItem from "../components/career-timeline-item.astro";
import TimelineIcon from "../components/timeline-icon.astro";
import { SITE } from "../config/site";
import Layout from "../layouts/layout.astro";

type StickyHeaderProps = {
  className?: string;
  zIndex: number;
};

const stickyHeaderClass = ({ className }: StickyHeaderProps) =>
  [
    "sticky top-0 pt-18 z-20 w-full border-b border-zinc-200/80 bg-zinc-100 py-2 text-sm font-semibold uppercase tracking-[0.22em] text-zinc-500 dark:border-zinc-800 dark:bg-zinc-900 dark:text-zinc-400",
    className,
  ]
    .filter(Boolean)
    .join(" ");
---

<Layout title={`About | ${SITE.name}`}>
  <section class="section-stack">
    <div class="space-y-4">
      <h1>About</h1>
      <p class="page-intro">
        A slightly more personal overview of how I work, what I care about, and
        the path that brought me from iOS into frontend engineering, independent
        projects.
      </p>
    </div>

    <div
      class="grid gap-6 md:grid-cols-[minmax(0,17rem)_minmax(0,1fr)] md:items-start"
    >
      <div class="md:sticky md:top-28">
        <img
          src="/assets/profile.jpeg"
          alt="Mate Papp is drinking espresso."
          width="3024"
          height="3024"
          loading="eager"
          fetchpriority="high"
          class="aspect-square w-full overflow-hidden rounded-3xl object-cover shadow-sm"
        />
      </div>

      <div class="section-stack">
        <div class="card prose-wrapper pt-5">
          <p>{SITE.description}</p>
          <p>
            During the week, I work as a senior frontend engineer at Glovo.
            <a href="#career">Previously</a>, I was also an iOS developer, and
            I&apos;ve co-founded a startup. On weekends, I like to build and
            iterate on my ideas.
          </p>

          <p>
            Outside work, I enjoy spending time with my friends and family by
            traveling together, playing board games, or meeting for great coffee
            or craft beer. A couple of my
            <a href="#hobbies">hobbies</a> are music, podcasts, visiting conferences
            and meetups, and playing team sports.
          </p>

          <p>
            Over the years, I’ve become passionate about coffee. Nowadays, I
            experiment with different brewing methods at home, mostly
            <a
              href="https://www.vbmespresso.com/en/home-barista/domobar-junior/"
              >espresso</a
            >,
            <a href="https://global.hario.com/sp_v60series.html">V60</a>,
            <a href="https://aeropress.com">AeroPress</a>, and
            <a
              href="https://global.hario.com/sp_mizudashi_cold_brewed_coffee.html#sei2"
              >cold brew</a
            >.
          </p>
        </div>

        <section id="career" class="section-stack">
          <div class="space-y-2">
            <p class="eyebrow">Timeline</p>
            <h2 class="font-sans font-semibold text-zinc-950 dark:text-zinc-50">
              Career
            </h2>
          </div>

          <div class="pb-4">
            <h3 class={stickyHeaderClass({ zIndex: 1 })} style={`z-index: 1;`}>
              2021
            </h3>
            <ul class="space-y-1 pt-4">
              <CareerTimelineItem month="November">
                <TimelineIcon slot="icon" name="currency-dollar" />
                <a
                  href="https://twitter.com/matepappcom/status/1464321635796803592"
                  class="text-link"
                >
                  Made my first 17,13$ online
                </a>
                by running
                <a href="https://historico.app" class="text-link">Historico</a>
                as a paid app for a month.
              </CareerTimelineItem>
              <CareerTimelineItem month="October">
                <TimelineIcon slot="icon" name="pencil" />
                Wrote my first
                <a
                  href="/thoughts/dipping-my-toes-into-writing"
                  class="text-link"
                >
                  blog post about writing
                </a>
                (meta-writing).
              </CareerTimelineItem>
              <CareerTimelineItem month="July">
                <TimelineIcon slot="icon" name="cog-6-tooth" />
                Transitioned to the Web Platform team within Glovo.
              </CareerTimelineItem>
              <CareerTimelineItem month="May">
                <TimelineIcon slot="icon" name="device-phone-mobile" />
                Released my first, indie iOS application,
                <a href="https://historico.app" class="text-link">Historico</a>
                to the App Store.
              </CareerTimelineItem>
            </ul>

            <h3
              class={stickyHeaderClass({ zIndex: 2, className: "mt-8" })}
              style={`z-index: 2;`}
            >
              2020
            </h3>
            <ul class="space-y-1 pt-4">
              <CareerTimelineItem month="September">
                <TimelineIcon slot="icon" name="home" />
                Moved to Barcelona.
              </CareerTimelineItem>
              <CareerTimelineItem month="June">
                <TimelineIcon slot="icon" name="briefcase" />
                Joined the Content &amp; Partners cluster within
                <a href="https://glovoapp.com" class="text-link">Glovo</a>
                as a senior frontend engineer.
              </CareerTimelineItem>
              <CareerTimelineItem month="April">
                <TimelineIcon slot="icon" name="code-bracket" />
                Built the first version of matepapp.com to learn and experiment with
                Tailwind CSS and Next.js.
              </CareerTimelineItem>
              <CareerTimelineItem month="March">
                <TimelineIcon slot="icon" name="x-circle" />
                Partly, because of the pandemic we decided to shut down Cogito and
                look for other opportunities.
              </CareerTimelineItem>
            </ul>

            <h3
              class={stickyHeaderClass({ zIndex: 3, className: "mt-8" })}
              style={`z-index: 3;`}
            >
              2019
            </h3>
            <ul class="space-y-1 pt-4">
              <CareerTimelineItem month="September">
                <TimelineIcon slot="icon" name="microphone" />
                Mentored a half-day
                <a
                  href="https://2019.jsconfbp.com/workshops/supercharge-jamstack"
                  class="text-link"
                >
                  workshop at JSConf BP &apos;19
                </a>
                about the beauty and possibilities of JAMstack.
              </CareerTimelineItem>
              <CareerTimelineItem month="July">
                <TimelineIcon slot="icon" name="briefcase" />
                Left Supercharge in order to focus on Cogito full-time. I&apos;ve
                led the development team and helped build the foundations and product
                of Cogito.
              </CareerTimelineItem>
              <CareerTimelineItem month="February">
                <TimelineIcon slot="icon" name="microphone" />
                Had my first &amp; second Meetup talks, plus a workshop within the
                company about GraphQL in general, and for iOS Developers.
              </CareerTimelineItem>
            </ul>

            <h3
              class={stickyHeaderClass({ zIndex: 4, className: "mt-8" })}
              style={`z-index: 4;`}
            >
              2018
            </h3>
            <ul class="space-y-1 pt-4">
              <CareerTimelineItem month="August">
                <TimelineIcon slot="icon" name="briefcase" />
                Moved to the Web team within Supercharge.
              </CareerTimelineItem>
              <CareerTimelineItem month="June">
                <TimelineIcon slot="icon" name="academic-cap" />
                Graduated as a Computer Engineer BSc at Budapest University of Technology
                and Economics. My final thesis was the very early version of Cogito.
              </CareerTimelineItem>
              <CareerTimelineItem month="March">
                <TimelineIcon slot="icon" name="cake" />
                Officially founded our startup,
                <a href="https://cogito.study" class="text-link">Cogito</a>
                with 5 friends of mine. Cogito is a community based, collaborative
                learning management platform mainly for universities. Initially, we
                participated in an incubator program, StartIT@K&amp;H.
              </CareerTimelineItem>
            </ul>

            <h3
              class={stickyHeaderClass({ zIndex: 5, className: "mt-8" })}
              style={`z-index: 5;`}
            >
              2017
            </h3>
            <ul class="space-y-1 pt-4">
              <CareerTimelineItem month="November">
                <TimelineIcon slot="icon" name="briefcase" />
                Joined one of the biggest digital agencies in Hungary,
                <a href="https://supercharge.io" class="text-link"
                  >Supercharge</a
                >
                as an iOS developer. I worked on several client projects, from huge
                mobile and internet banking systems to small, early-stage startup
                products.
              </CareerTimelineItem>
              <CareerTimelineItem month="April">
                <TimelineIcon slot="icon" name="microphone" />
                Held a design principles workshop for new joiners at
                <a href="https://simonyi.bme.hu" class="text-link">
                  Simonyi Károly College for Advanced Studies
                </a>.
              </CareerTimelineItem>
              <CareerTimelineItem month="March">
                <TimelineIcon slot="icon" name="briefcase" />
                Started a new job at Fornax ICT as an iOS developer. As part of a
                cross-functional team, we were building enterprise-level project and
                resource management applications.
              </CareerTimelineItem>
            </ul>

            <h3
              class={stickyHeaderClass({ zIndex: 6, className: "mt-8" })}
              style={`z-index: 6;`}
            >
              2016
            </h3>
            <ul class="space-y-1 pt-4">
              <CareerTimelineItem month="December">
                <TimelineIcon slot="icon" name="megaphone" />
                Joined the organizer team of the
                <a
                  href="https://www.facebook.com/events/bme-i-épület/xiv-simonyi-konferencia/1113033802140234/"
                  class="text-link"
                >
                  XIV. Simonyi Conference
                </a>.
              </CareerTimelineItem>
              <CareerTimelineItem month="July">
                <TimelineIcon slot="icon" name="briefcase" />
                Started my professional career as an iOS developer intern, later junior,
                at POSSIBLE CEE.
              </CareerTimelineItem>
              <CareerTimelineItem month="April">
                <TimelineIcon slot="icon" name="academic-cap" />
                Participated in UX Studio&apos;s practice-oriented UX and UI training
                program.
              </CareerTimelineItem>
            </ul>

            <h3
              class={stickyHeaderClass({ zIndex: 7, className: "mt-8" })}
              style={`z-index: 7;`}
            >
              2015
            </h3>
            <ul class="space-y-1 pt-4">
              <CareerTimelineItem month="November">
                <TimelineIcon slot="icon" name="device-phone-mobile" />
                Started learning iOS application development in my free time.
              </CareerTimelineItem>
              <CareerTimelineItem month="October">
                <TimelineIcon slot="icon" name="briefcase" />
                Joined
                <a href="https://schdesign.hu" class="text-link"
                  >Schönherz Design Studio</a
                >, the design-focused volunteer team within Simonyi Károly
                College for Advanced Studies.
              </CareerTimelineItem>
              <CareerTimelineItem month="June - September">
                <TimelineIcon slot="icon" name="globe-alt" />
                Worked for three months in the US as a summer camp staff member. I
                had a chance to visit New York, Philadelphia, Washington DC, Niagara
                Falls, and Los Angeles.
              </CareerTimelineItem>
            </ul>

            <h3
              class={stickyHeaderClass({ zIndex: 8, className: "mt-8" })}
              style={`z-index: 8;`}
            >
              2014
            </h3>
            <ul class="space-y-1 pt-4">
              <CareerTimelineItem month="August">
                <TimelineIcon slot="icon" name="home" />
                Moved to Budapest and started university at Budapest University of
                Technology and Economics as a Computer Engineer.
              </CareerTimelineItem>
              <CareerTimelineItem month="June">
                <TimelineIcon slot="icon" name="academic-cap" />
                Finished high school at Nagy Lajos Gimnázium Szombathely.
              </CareerTimelineItem>
            </ul>
          </div>
        </section>

        <section id="hobbies" class="section-stack">
          <div class="space-y-2">
            <p class="eyebrow">Life outside work</p>
            <h2 class="font-sans font-semibold text-zinc-950 dark:text-zinc-50">
              Hobbies
            </h2>
          </div>
          <ul class="grid list-none grid-cols-1 gap-3 sm:grid-cols-2">
            <li
              class="border-t border-zinc-200/80 pt-3 text-sm text-zinc-700 dark:border-zinc-800 dark:text-zinc-300"
            >
              spending time with friends &amp; family
            </li>
            <li
              class="border-t border-zinc-200/80 pt-3 text-sm text-zinc-700 dark:border-zinc-800 dark:text-zinc-300"
            >
              brewing coffee
            </li>
            <li
              class="border-t border-zinc-200/80 pt-3 text-sm text-zinc-700 dark:border-zinc-800 dark:text-zinc-300"
            >
              listening to podcasts
            </li>
            <li
              class="border-t border-zinc-200/80 pt-3 text-sm text-zinc-700 dark:border-zinc-800 dark:text-zinc-300"
            >
              reading books &amp; articles
            </li>
            <li
              class="border-t border-zinc-200/80 pt-3 text-sm text-zinc-700 dark:border-zinc-800 dark:text-zinc-300"
            >
              playing team sports
            </li>
            <li
              class="border-t border-zinc-200/80 pt-3 text-sm text-zinc-700 dark:border-zinc-800 dark:text-zinc-300"
            >
              attending meetups &amp; conferences
            </li>
            <li
              class="border-t border-zinc-200/80 pt-3 text-sm text-zinc-700 dark:border-zinc-800 dark:text-zinc-300"
            >
              traveling
            </li>
            <li
              class="border-t border-zinc-200/80 pt-3 text-sm text-zinc-700 dark:border-zinc-800 dark:text-zinc-300"
            >
              functional training
            </li>
            <li
              class="border-t border-zinc-200/80 pt-3 text-sm text-zinc-700 dark:border-zinc-800 dark:text-zinc-300"
            >
              cycling
            </li>
            <li
              class="border-t border-zinc-200/80 pt-3 text-sm text-zinc-700 dark:border-zinc-800 dark:text-zinc-300"
            >
              playing board games
            </li>
            <li
              class="border-t border-zinc-200/80 pt-3 text-sm text-zinc-700 dark:border-zinc-800 dark:text-zinc-300"
            >
              cooking
            </li>
            <li
              class="border-t border-zinc-200/80 pt-3 text-sm text-zinc-700 dark:border-zinc-800 dark:text-zinc-300"
            >
              learning new things
            </li>
          </ul>
        </section>
      </div>
    </div>
  </section>
</Layout>
