---
import { ButtonLink } from "../components/button-link";
import Layout from "../components/layout.astro";
import { SITE } from '../site';
---

<Layout title={SITE.title}>
  <section class="section-stack">
    <div class="space-y-5">
      <h1>Hey, I&apos;m Mate.</h1>
      <p class="page-intro">
        Software engineer, indie maker, and curious home barista. I write about software,
        building useful products, and the habits that help creative work last.
      </p>
      <div class="border-t border-zinc-200/80 pt-5 dark:border-zinc-800">
        <p class="max-w-[68ch] leading-8 text-zinc-700 dark:text-zinc-300">
          {SITE.description}
        </p>
        <div class="mt-5 flex flex-wrap items-center gap-x-5 gap-y-3">
          <ButtonLink href="/thoughts" showArrowIcon={true}>Read My Thoughts</ButtonLink>
          <ButtonLink href="/about" showArrowIcon={true}>More About Me</ButtonLink>
        </div>
      </div>
    </div>
  </section>
</Layout>
