---
import { getCollection, render } from 'astro:content';

import Layout from "../../components/layout.astro";
import { canonicalUrl, pageTitle } from '../../site';

export async function getStaticPaths() {
  const thoughts = (await getCollection('thoughts')).filter(({ data }) => data.published);

  return thoughts.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const canonical = canonicalUrl(`/thoughts/${entry.data.slug}`);
const image = canonicalUrl(`/assets/thoughts/${entry.data.slug}/meta.png`);
---

<Layout
  title={pageTitle(entry.data.title)}
  description={entry.data.excerpt}
  canonical={canonical}
  image={image}
>
  <div>
    <h1>{entry.data.title}</h1>
    <div class="text-tertiary mt-4 text-sm font-medium uppercase tracking-wider">
      <span>{entry.data.createdAt}</span> · <span>{entry.data.readingTime}</span>
    </div>
  </div>

  <div class="prose-wrapper">
    <Content />
  </div>
</Layout>
